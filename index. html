class QueryBuilder {
  constructor(client, table) {
    this.client = client;
    this.table = table;
    this.params = [];
    this.method = 'GET';
    this.body = null;
    this._selectCols = '*';
  }

  select(cols = '*') {
    this._selectCols = cols;
    this.method = 'GET';
    return this;
  }

  eq(col, val) {
    this.params.push(`${col}=eq.${encodeURIComponent(val)}`);
    return this;
  }

  order(col, { ascending = true } = {}) {
    this.params.push(`order=${col}.${ascending ? 'asc' : 'desc'}`);
    return this;
  }

  limit(n) {
    this.params.push(`limit=${n}`);
    return this;
  }

  insert(data) {
    this.method = 'POST';
    this.body = Array.isArray(data) ? data : [data];
    return this;
  }

  delete() {
    this.method = 'DELETE';
    return this;
  }

  async execute() {
    const qs = this.params.length ? '?' + this.params.join('&') : '';
    const url = `${this.client.url}/rest/v1/${this.table}${qs}`;
    
    const opts = {
      method: this.method,
      headers: { ...this.client.headers() }
    };

    if (this.method === 'GET') {
      opts.headers['Accept'] = 'application/json';
      if (this._selectCols !== '*') {
        opts.headers['Accept'] = 'application/json';
        this.params.unshift(`select=${this._selectCols}`);
        // РџРµСЂРµСЃС‚СЂРѕРёРј URL
        const qs2 = '?' + this.params.join('&');
        const url2 = `${this.client.url}/rest/v1/${this.table}${qs2}`;
        const r = await fetch(url2, opts);
        const d = await r.json();
        return { data: d, error: r.ok ? null : d };
      }
    }

    if (this.body) {
      opts.body = JSON.stringify(this.body);
    }

    const r = await fetch(url, opts);
    const d = r.status === 204 ? [] : await r.json();
    return { data: d, error: r.ok ? null : d };
  }

  then(resolve, reject) {
    return this.execute().then(resolve, reject);
  }
}

// РЈРїСЂРѕС‰С‘РЅРЅС‹Р№ API РґР»СЏ СЂР°Р±РѕС‚С‹ СЃ Supabase
const db = {
