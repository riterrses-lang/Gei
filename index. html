      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=representation'
      },
      body: JSON.stringify(data)
    });
    return r.json();
  },

  async delete(table, filters = {}) {
    let qs = '';
    const parts = Object.entries(filters).map(([k, v]) => `${k}=eq.${encodeURIComponent(v)}`);
    if (parts.length) qs = '?' + parts.join('&');

    const r = await fetch(`${SUPABASE_URL}/rest/v1/${table}${qs}`, {
      method: 'DELETE',
      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
        'Prefer': 'return=representation'
      }
    });
    if (r.status === 204) return [];
    return r.json();
  }
};

// =============================================
//  РЁРР¤Р РћР’РђРќРР• (XOR + Base64 + Caesar)
// =============================================
const CIPHER_KEY = 'SecureChatK3y!@#$%^&*()_+xYzAbC';

function encrypt(text) {
  // 1. XOR СЃ РєР»СЋС‡РѕРј
  let xored = '';
  for (let i = 0; i < text.length; i++) {
    xored += String.fromCharCode(
      text.charCodeAt(i) ^ CIPHER_KEY.charCodeAt(i % CIPHER_KEY.length)
    );
  }
  // 2. Base64
  const b64 = btoa(unescape(encodeURIComponent(xored)));
  // 3. РџРµСЂРµРјРµС€Р°РµРј СЃРёРјРІРѕР»С‹ (Caesar РЅР° СѓСЂРѕРІРЅРµ base64)
  const shifted = b64.split('').map(c => {
    const code = c.charCodeAt(0);
    if (code >= 65 && code <= 90) return String.fromCharCode(((code - 65 + 13) % 26) + 65);
    if (code >= 97 && code <= 122) return String.fromCharCode(((code - 97 + 13) % 26) + 97);
    if (code >= 48 && code <= 57) return String.fromCharCode(((code - 48 + 5) % 10) + 48);
    return c;
  }).join('');
  // 4. Р”РѕР±Р°РІР»СЏРµРј РїСЂРµС„РёРєСЃ С‡С‚РѕР±С‹ Р±С‹Р»Рѕ С‚РѕС‡РЅРѕ РЅРµС‡РёС‚Р°РµРјРѕ
  return 'вџ¦' + shifted + 'вџ§';
}

function decrypt(cipherText) {
  try {
    // РЈР±РёСЂР°РµРј РїСЂРµС„РёРєСЃ/СЃСѓС„С„РёРєСЃ
    let text = cipherText;
    if (text.startsWith('вџ¦') && text.endsWith('вџ§')) {
      text = text.slice(1, -1);
    }
    // РћР±СЂР°С‚РЅС‹Р№ Caesar
    const unshifted = text.split('').map(c => {
      const code = c.charCodeAt(0);
      if (code >= 65 && code <= 90) return String.fromCharCode(((code - 65 + 13) % 26) + 65);
      if (code >= 97 && code <= 122) return String.fromCharCode(((code - 97 + 13) % 26) + 97);
      if (code >= 48 && code <= 57) return String.fromCharCode(((code - 48 + 5) % 10) + 48);
      return c;
    }).join('');
    // РћР±СЂР°С‚РЅС‹Р№ Base64
    const xored = decodeURIComponent(escape(atob(unshifted)));
    // РћР±СЂР°С‚РЅС‹Р№ XOR
    let result = '';
    for (let i = 0; i < xored.length; i++) {
      result += String.fromCharCode(
        xored.charCodeAt(i) ^ CIPHER_KEY.charCodeAt(i % CIPHER_KEY.length)
      );
    }
    return result;
  } catch(e) {
    return '[РѕС€РёР±РєР° СЂР°СЃС€РёС„СЂРѕРІРєРё]';
  }
}

