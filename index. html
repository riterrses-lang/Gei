  `).join('');
}

function leaveChat(e, chatId) {
  e.stopPropagation();
  myChats = myChats.filter(c => c.id !== chatId);
  localStorage.setItem('myChats', JSON.stringify(myChats));
  
  if (currentChat?.id === chatId) {
    currentChat = null;
    document.getElementById('welcomeScreen').style.display = 'flex';
    document.getElementById('activeChat').style.display = 'none';
    if (realtimeSubscription) {
      realtimeSubscription.close();
      realtimeSubscription = null;
    }
  }
  renderChatList();
  showToast('Р’С‹ РїРѕРєРёРЅСѓР»Рё С‡Р°С‚');
}

// =============================================
//  РћРўРљР Р«РўРР• Р§РђРўРђ
// =============================================
async function openChat(chat) {
  currentChat = chat;
  
  // UI РїРµСЂРµРєР»СЋС‡РµРЅРёРµ
  document.getElementById('welcomeScreen').style.display = 'none';
  const activeChat = document.getElementById('activeChat');
  activeChat.style.display = 'flex';
  
  document.getElementById('activeChatName').textContent = chat.name;
  document.getElementById('activeChatToken').textContent = chat.token;
  document.getElementById('activeChatSub').textContent = `С‚РѕРєРµРЅ: ${chat.token} В· Р·Р°С€РёС„СЂРѕРІР°РЅРѕ`;
  
  renderChatList();
  
  // РћС‚РїРёСЃС‹РІР°РµРјСЃСЏ РѕС‚ РїСЂРµРґС‹РґСѓС‰РµРіРѕ
  if (realtimeSubscription) {
    realtimeSubscription.close();
    realtimeSubscription = null;
  }
  
  // Р—Р°РіСЂСѓР¶Р°РµРј СЃРѕРѕР±С‰РµРЅРёСЏ
  await loadMessages();
  
  // РџРѕРґРїРёСЃС‹РІР°РµРјСЃСЏ РЅР° realtime
  subscribeToMessages();
  
  document.getElementById('messageInput').focus();
}

// =============================================
//  Р—РђР“Р РЈР—РљРђ РЎРћРћР‘Р©Р•РќРР™
// =============================================
async function loadMessages() {
  const container = document.getElementById('messagesContainer');
  container.innerHTML = `
    <div style="display:flex;align-items:center;justify-content:center;flex:1;color:var(--text-muted);">
      <div class="loading-dots"><span></span><span></span><span></span></div>
    </div>
  `;

  try {
    const messages = await db.select(
      'messages',
      { chat_id: currentChat.id },
      { order: 'created_at.asc' }
    );
    
    renderMessages(messages || []);
  } catch(e) {
    container.innerHTML = '<div style="text-align:center;color:var(--danger);padding:20px;">РћС€РёР±РєР° Р·Р°РіСЂСѓР·РєРё</div>';
    console.error(e);
  }
}

// =============================================
//  Р Р•РќР”Р•Р  РЎРћРћР‘Р©Р•РќРР™
// =============================================
function renderMessages(messages) {
  const container = document.getElementById('messagesContainer');
  
  if (!messages.length) {
    container.innerHTML = `
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;gap:8px;color:var(--text-muted);">
        <span style="font-size:40px;opacity:0.3">рџ”’</span>
        <p style="font-size:13px;">РЎРѕРѕР±С‰РµРЅРёР№ РїРѕРєР° РЅРµС‚. РќР°С‡РЅРёС‚Рµ РѕР±С‰РµРЅРёРµ!</p>
      </div>
    `;
    return;
  }

  // Р“СЂСѓРїРїРёСЂСѓРµРј РїРѕ РѕС‚РїСЂР°РІРёС‚РµР»СЋ Рё РІСЂРµРјРµРЅРё
  const groups = [];
  let lastSender = null;
  let lastGroup = null;

  messages.forEach(msg => {
    const decrypted = decrypt(msg.content);
    const isOwn = msg.sender_id === currentUser.id;
    
    if (lastSender !== msg.sender_id) {
      lastGroup = {
        sender: msg.sender_name,
        senderId: msg.sender_id,
        isOwn,
        messages: []
      };
      groups.push(lastGroup);
      lastSender = msg.sender_id;
    }
    
    lastGroup.messages.push({
      id: msg.id,
      text: decrypted,
      time: formatTime(msg.created_at)
    });
  });

  container.innerHTML = groups.map(group => `
    <div class="message-group ${group.isOwn ? 'own' : 'other'}">
      <div class="message-sender">${group.isOwn ? 'Р’С‹' : escHtml(group.sender)}</div>
      ${group.messages.map((msg, i) => `
        <div class="message-bubble" data-id="${msg.id}">
          ${escHtml(msg.text)}
        </div>
      `).join('')}
      <div class="message-time">${group.messages[group.messages.length - 1].time}</div>
    </div>
  `).join('');

  scrollToBottom();
}

// =============================================
//  РћРўРџР РђР’РљРђ РЎРћРћР‘Р©Р•РќРРЇ
// =============================================
async function sendMessage() {
  const input = document.getElementById('messageInput');
  const text = input.value.trim();
  
  if (!text || !currentChat) return;
  
  input.value = '';
  autoResize(input);
  document.getElementById('sendBtn').disabled = true;

  try {
    // РЁРёС„СЂСѓРµРј РїРµСЂРµРґ РѕС‚РїСЂР°РІРєРѕР№
    const encrypted = encrypt(text);
    
    // РЎС‡РёС‚Р°РµРј СЃРєРѕР»СЊРєРѕ СЃРѕРѕР±С‰РµРЅРёР№ Сѓ С‚РµРєСѓС‰РµРіРѕ РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ РІ СЌС‚РѕРј С‡Р°С‚Рµ
    const allMessages = await db.select('messages', { chat_id: currentChat.id }, { order: 'created_at.asc' });
    const myMessages = (allMessages || []).filter(m => m.sender_id === currentUser.id);
    
    // Р•СЃР»Рё СѓР¶Рµ 10 - СѓРґР°Р»СЏРµРј СЃР°РјРѕРµ СЃС‚Р°СЂРѕРµ
    if (myMessages.length >= 10) {
      const toDelete = myMessages[0];
      await db.delete('messages', { id: toDelete.id });
    }

    // РћС‚РїСЂР°РІР»СЏРµРј Р·Р°С€РёС„СЂРѕРІР°РЅРЅРѕРµ СЃРѕРѕР±С‰РµРЅРёРµ
    await db.insert('messages', {
      chat_id: currentChat.id,
      sender_id: currentUser.id,
      sender_name: currentUser.name,
      content: encrypted
    });

  } catch(e) {
    showToast('РћС€РёР±РєР° РѕС‚РїСЂР°РІРєРё', 'error');
    input.value = text;
    console.error(e);
  }

  document.getElementById('sendBtn').disabled = false;
  input.focus();
}

// =============================================
//  REALTIME РџРћР”РџРРЎРљРђ (WebSocket С‡РµСЂРµР· Supabase)
// =============================================
function subscribeToMessages() {
  // РСЃРїРѕР»СЊР·СѓРµРј Supabase Realtime С‡РµСЂРµР· WebSocket
  const wsUrl = SUPABASE_URL.replace('https://', 'wss://') + '/realtime/v1/websocket?apikey=' + SUPABASE_ANON_KEY + '&vsn=1.0.0';
  
  const ws = new WebSocket(wsUrl);
  realtimeSubscription = ws;

  ws.onopen = () => {
    // РџРѕРґРєР»СЋС‡Р°РµРјСЃСЏ Рє РєР°РЅР°Р»Сѓ
    ws.send(JSON.stringify({
      topic: `realtime:public:messages:chat_id=eq.${currentChat.id}`,
      event: 'phx_join',
      payload: {},
      ref: '1'
    }));
  };

  ws.onmessage = async (event) => {
    try {
      const msg = JSON.parse(event.data);
      
      if (msg.event === 'phx_reply' && msg.payload?.status === 'ok') {
        // РЈСЃРїРµС€РЅРѕ РїРѕРґРїРёСЃР°Р»РёСЃСЊ
      }
      
      if (msg.event === 'INSERT' || msg.event === 'DELETE' || msg.event === 'UPDATE') {
        // РџРµСЂРµР·Р°РіСЂСѓР¶Р°РµРј СЃРѕРѕР±С‰РµРЅРёСЏ РїСЂРё Р»СЋР±РѕРј РёР·РјРµРЅРµРЅРёРё
        if (currentChat) {
          await loadMessages();
        }
      }
    } catch(e) {}
  };

  ws.onerror = () => {
    // Fallback вЂ” polling РєР°Р¶РґС‹Рµ 2 СЃРµРєСѓРЅРґС‹
    startPolling();
  };

  ws.onclose = () => {
    // РџСЂРё Р·Р°РєСЂС‹С‚РёРё вЂ” polling
    if (currentChat) startPolling();
  };

  // Heartbeat
  const heartbeat = setInterval(() => {
    if (ws.readyState === WebSocket.OPEN) {
      ws.send(JSON.stringify({ topic: 'phoenix', event: 'heartbeat', payload: {}, ref: '0' }));
    } else {
      clearInterval(heartbeat);
    }
  }, 20000);
}

// Polling fallback
let pollingInterval = null;
let lastMessageCount = 0;

function startPolling() {
  if (pollingInterval) clearInterval(pollingInterval);
  
  pollingInterval = setInterval(async () => {
    if (!currentChat) {
      clearInterval(pollingInterval);
      return;
    }
    
    try {
      const messages = await db.select(
        'messages',
        { chat_id: currentChat.id },
        { order: 'created_at.asc' }
      );
      
      if (messages && messages.length !== lastMessageCount) {
        lastMessageCount = messages.length;
        renderMessages(messages);
      }
    } catch(e) {}
  }, 1500);
}

// =============================================
//  Р’РЎРџРћРњРћР“РђРўР•Р›Р¬РќР«Р• Р¤РЈРќРљР¦РР
// =============================================
function handleKeyDown(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function autoResize(textarea) {
  textarea.style.height = 'auto';
  textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
}

function scrollToBottom() {
  const container = document.getElementById('messagesContainer');
  setTimeout(() => {
    container.scrollTop = container.scrollHeight;
  }, 50);
}

function formatTime(isoString) {
  const d = new Date(isoString);
  return d.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
}

function escHtml(text) {
  const d = document.createElement('div');
  d.textContent = text;
  return d.innerHTML;
}

function copyToken() {
  if (!currentChat) return;
  navigator.clipboard.writeText(currentChat.token);
  showToast('РўРѕРєРµРЅ СЃРєРѕРїРёСЂРѕРІР°РЅ!', 'success');
}

function copyNewToken() {
  const token = document.getElementById('newTokenValue').textContent;
  navigator.clipboard.writeText(token);
  showToast('РўРѕРєРµРЅ СЃРєРѕРїРёСЂРѕРІР°РЅ!', 'success');
}

// =============================================
//  РњРћР”РђР›Р¬РќР«Р• РћРљРќРђ
// =============================================
function showCreateModal() {
  document.getElementById('createModal').style.display = 'flex';
  setTimeout(() => document.getElementById('createChatName').focus(), 100);
}

function showJoinModal() {
  document.getElementById('joinModal').style.display = 'flex';
  setTimeout(() => document.getElementById('joinToken').focus(), 100);
}

function closeModal(id) {
  document.getElementById(id).style.display = 'none';
}

function closeModalOutside(e, id) {
  if (e.target.classList.contains('modal-overlay')) {
    closeModal(id);
  }
}

// =============================================
//  РЈР’Р•Р”РћРњР›Р•РќРРЇ
// =============================================
function showToast(message, type = '') {
  const existing = document.querySelector('.toast');
  if (existing) existing.remove();
  
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  document.body.appendChild(toast);
  
  setTimeout(() => {
    toast.style.animation = 'none';
    toast.style.opacity = '0';
    toast.style.transform = 'translateY(10px)';
    toast.style.transition = 'all 0.3s ease';
    setTimeout(() => toast.remove(), 300);
  }, 2500);
}

// Keyboard shortcuts
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    ['createModal', 'joinModal', 'tokenModal'].forEach(closeModal);
  }
});
